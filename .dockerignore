# Version control
.git
.gitignore
.gitattributes
.github

# Dependencies (always installed fresh in container)
node_modules
**/node_modules

# Build outputs / caches
.next
**/.next
dist
**/dist
*.tsbuildinfo
**/*.tsbuildinfo
.turbo
.cache

# Local env (must never leak into image)
.env
.env.*
**/.env
**/.env.*

# Editor / OS
.vscode
.idea
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Repo metadata not needed inside images
README.md
CLAUDE.md

# Docker / Compose itself
**/Dockerfile
.dockerignore
compose.yaml
docker-compose.yml
docker-compose.yaml

# Production infra files (not needed inside app images)
infrastructure
