# Copy to deploy/.env.local on the VM and fill in real values.
# All services in compose.yaml read this file via `env_file:`.
#
# POSTGRES_USER / POSTGRES_DB / WEB_PORT are hardcoded in compose.yaml.
# IMAGE_TAG is read from shell env at parse time (default: latest), not from
# this file. Set it inline for rollback: `IMAGE_TAG=sha-xxx docker compose ...`.

# --- Postgres ---------------------------------------------------------------
POSTGRES_PASSWORD=

# --- Shared (web + bot + migrate) -------------------------------------------
# Use the in-network hostnames `postgres` and `redis`.
DATABASE_URL=postgres://postgres:CHANGE_ME@postgres:5432/hannario
# DATABASE_SSL=require       # optional: require|allow|prefer|verify-full
REDIS_URL=redis://redis:6379

# --- Web only ---------------------------------------------------------------
APP_BASE_URL=https://your.public.host
COGNITO_ISSUER=https://cognito-idp.<region>.amazonaws.com/<userPoolId>
COGNITO_LOGIN_DOMAIN=https://<prefix>.auth.<region>.amazoncognito.com
COGNITO_CLIENT_ID=
COGNITO_CLIENT_SECRET=

# --- Bot only ---------------------------------------------------------------
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-5-mini
# LOG_LEVEL=info
